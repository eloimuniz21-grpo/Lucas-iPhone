# Copie para .env.local e preencha com os valores do projeto Supabase
# (Project Settings > API). Mesma chave anon/publishable do site público —
# a proteção real vem das políticas de RLS, que só liberam devices/sales/
# etc. para quem está na tabela public.admins.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_OU_PUBLISHABLE
