# Copie este arquivo para .env.local e preencha com os valores do seu
# projeto Supabase (Project Settings > API). A chave "anon/publishable" é
# segura para expor no frontend — a proteção real vem das políticas de RLS.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_OU_PUBLISHABLE

# Número do WhatsApp do Lucas, formato internacional sem símbolos.
# Ex: 55 11 9XXXX-XXXX vira 55119XXXXXXXX
VITE_WHATSAPP_NUMBER=5511900000000
